# Example UserParameter file for Proxmox RAID SMART monitoring.
# Save as:
#   /etc/zabbix/zabbix_agent2.d/proxmox-raid-smart.conf
#
# Adjust the command arguments to match your real script implementation.

UserParameter=raid.pd.discovery,sudo /usr/local/bin/proxmox_raid_pd_attr.sh discover /dev/sda
UserParameter=raid.pd.health[*],sudo /usr/local/bin/proxmox_raid_pd_attr.sh health "$1"
UserParameter=raid.pd.wear[*],sudo /usr/local/bin/proxmox_raid_pd_attr.sh wear "$1"
UserParameter=raid.pd.type[*],sudo /usr/local/bin/proxmox_raid_pd_attr.sh type "$1"
UserParameter=raid.pd.dynamic.status[*],sudo /usr/local/bin/proxmox_raid_pd_attr.sh dynamic "$1"
